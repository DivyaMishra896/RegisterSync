# ====================================
# Suraksha — Environment Configuration
# ====================================

# LLM Mode
# "ollama" = Local AI via Ollama (requires Ollama running)
# "mock"   = Regex/NLP fallback (no AI needed, for development)
LLM_MODE=ollama

# Ollama Configuration (only used when LLM_MODE=ollama)
# Change OLLAMA_MODEL to swap models — no code changes needed!
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi4-mini:latest
# Other model options:
#   phi3:mini    — 3.8B, fast, good for 4GB VRAM (recommended)
#   gemma2:2b    — 2.7B, very fast, decent quality
#   mistral      — 7B, best quality, needs 5GB+ VRAM
#   llama3       — 8B, best quality, needs 5GB+ VRAM
#   tinyllama    — 1.1B, very fast, lower quality

# Database (SQLite for fully offline operation)
DATABASE_URL=sqlite:///./suraksha.db

# CORS origin for frontend dev server
FRONTEND_URL=http://localhost:5173
