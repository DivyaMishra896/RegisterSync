# --- LLM Extraction Mode ---
# "ollama" -> Uses a local LLM via Ollama for real AI extraction (Default)
# "mock"   -> No external dependencies, uses built-in mock data for testing
LLM_MODE=ollama

# --- Ollama Settings ---
# Only needed if LLM_MODE=ollama. Ensure Ollama is running and the model is pulled.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:1.5b

# --- Database Configuration ---
# Path to the SQLite database
DATABASE_URL=sqlite:///./suraksha.db

# --- Frontend Configuration ---
# URL where the frontend application is running, used for CORS
FRONTEND_URL=http://localhost:5173