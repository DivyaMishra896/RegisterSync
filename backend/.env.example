# Google Gemini API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Set to "mock" to use hardcoded LLM responses (no API key needed)
# Set to "live" to use real Gemini API
LLM_MODE=mock

# Database URL
# For NeonDB (PostgreSQL): postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname
# For local SQLite:         sqlite:///./suraksha.db
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname

# CORS origin for frontend dev server
FRONTEND_URL=http://localhost:5173
